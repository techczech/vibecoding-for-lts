{
  "name": "vibecoding-for-lts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:content": "tsx scripts/build-content.ts",
    "dev": "bun run build:content && vite --host 127.0.0.1",
    "build": "bun run build:content && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "audit:single": "node scripts/audit-single-html.mjs dist/index.html --strict"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.2.4",
    "vite-plugin-singlefile": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
